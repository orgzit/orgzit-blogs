---
interface BreadcrumbItem {
  label: string;
  href?: string;
}

interface Props {
  items: BreadcrumbItem[];
}

const { items } = Astro.props;
---
<nav aria-label="Breadcrumb">
  <ol class="flex flex-wrap items-center gap-1.5 text-sm text-slate-500">
    {items.map((item, i) => (
      <li class="flex items-center gap-1.5">
        {i > 0 && <span aria-hidden="true">›</span>}
        {item.href
          ? <a href={item.href} class="hover:text-brand-600 transition-colors">{item.label}</a>
          : <span class="text-slate-700 font-medium line-clamp-1">{item.label}</span>
        }
      </li>
    ))}
  </ol>
</nav>
