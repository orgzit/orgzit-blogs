---
const year = new Date().getFullYear();
---
<footer class="bg-slate-900 text-slate-400 mt-20">
  <div class="max-w-6xl mx-auto px-6 py-12">
    <div class="grid sm:grid-cols-2 md:grid-cols-4 gap-8 mb-10">
      <div class="sm:col-span-2">
        <a href="/blog/" class="text-white font-bold text-lg mb-3 block">Orgzit Blog</a>
        <p class="text-sm leading-relaxed max-w-xs">
          Practical insights on CRM, productivity, no-code tools, and business automation for growing teams.
        </p>
      </div>
      <div>
        <h3 class="text-white text-sm font-semibold mb-4 uppercase tracking-wider">Topics</h3>
        <ul class="space-y-2 text-sm">
          <li><a href="/blog/category/crm/" class="hover:text-white transition-colors">CRM</a></li>
          <li><a href="/blog/category/productivity/" class="hover:text-white transition-colors">Productivity</a></li>
          <li><a href="/blog/category/no-code/" class="hover:text-white transition-colors">No Code</a></li>
          <li><a href="/blog/category/sales/" class="hover:text-white transition-colors">Sales</a></li>
        </ul>
      </div>
      <div>
        <h3 class="text-white text-sm font-semibold mb-4 uppercase tracking-wider">Orgzit</h3>
        <ul class="space-y-2 text-sm">
          <li><a href="https://orgzit.com" class="hover:text-white transition-colors">Website</a></li>
          <li><a href="https://orgzit.com/book-demo/" class="hover:text-white transition-colors">Book a Demo</a></li>
          <li><a href="/blog/rss.xml" class="hover:text-white transition-colors">RSS Feed</a></li>
          <li><a href="/blog/sitemap.xml" class="hover:text-white transition-colors">Sitemap</a></li>
        </ul>
      </div>
    </div>
    <div class="border-t border-slate-800 pt-6 text-xs text-center">
      © {year} Orgzit. All rights reserved.
    </div>
  </div>
</footer>
