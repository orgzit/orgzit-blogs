---
import categoriesData from '@/content/data/categories.json';
import { withBase } from '@lib/paths';

const topCategories = (categoriesData as any[])
  .sort((a, b) => b.count - a.count)
  .slice(0, 6);
---
<header class="navbar">
  <nav class="navbar-inner">

    <a href={withBase('/')} class="navbar-logo">
      <img src={withBase('/orgzit-logo.png')} alt="Orgzit" class="navbar-logo-img" width="99" height="28" />
      <span class="navbar-logo-suffix">Blog</span>
    </a>

    <div class="navbar-links">
      <a href={withBase('/')} class="navbar-link">
        All Posts
      </a>

      {topCategories.length > 0 && (
        <div class="navbar-dropdown">
          <button class="navbar-dropdown-btn">
            Categories
            <svg class="icon-sm" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <div class="navbar-dropdown-panel">
            {topCategories.map((cat: any) => (
              <a
                href={withBase(`/category/${cat.slug}/`)}
                class="navbar-dropdown-item"
              >
                {cat.name}
                <span class="navbar-dropdown-count">({cat.count})</span>
              </a>
            ))}
          </div>
        </div>
      )}

      <a href={withBase('/search/')} class="navbar-link">
        Search
      </a>
    </div>

    <a
      href="https://orgzit.com/book-demo/"
      class="navbar-cta"
      onclick="if (window.Calendly) { Calendly.initPopupWidget({ url: 'https://calendly.com/orgzit/personalized-consultation-30' }); return false; }"
    >
      Book a Demo →
    </a>

    <button id="mobile-menu-btn" class="navbar-mobile-btn">
      <svg class="icon-md" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </nav>

  <div id="mobile-menu" class="navbar-mobile-menu">
    <a href={withBase('/')} class="navbar-mobile-link">All Posts</a>
    {topCategories.length > 0 && (
      <div class="navbar-mobile-categories">
        <div class="navbar-mobile-categories-label">Categories</div>
        {topCategories.map((cat: any) => (
          <a href={withBase(`/category/${cat.slug}/`)} class="navbar-mobile-category-link">
            {cat.name}
          </a>
        ))}
      </div>
    )}
    <a href={withBase('/search/')} class="navbar-mobile-link">Search</a>
    <a
      href="https://orgzit.com/book-demo/"
      class="navbar-mobile-cta"
      onclick="if (window.Calendly) { Calendly.initPopupWidget({ url: 'https://calendly.com/orgzit/personalized-consultation-30' }); return false; }"
    >
      Book a Demo →
    </a>
  </div>
</header>

<script>
  document.getElementById('mobile-menu-btn')?.addEventListener('click', () => {
    document.getElementById('mobile-menu')?.classList.toggle('is-open');
  });
</script>
