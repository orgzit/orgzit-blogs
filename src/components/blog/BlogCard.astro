---
import { formatDate } from '@lib/dates';
import { withBase } from '@lib/paths';
import { slugify } from '@lib/slugify';
import type { Post } from '@app-types/blog';

interface Props {
  post: Omit<Post, 'readingTime' | 'slug'>;
  slug: string;
}

const { post, slug } = Astro.props;
---
<article class="blog-card">
  <a href={`/blog/${slug}/`} class="blog-card-thumb">
    {post.featuredImage
      ? (
        <img
          src={withBase(post.featuredImage)}
          alt={post.featuredImageAlt}
          class="blog-card-img"
          loading="lazy"
          width="400"
          height="225"
        />
      )
      : (
        <div class="blog-card-placeholder">
          <span class="blog-card-placeholder-letter">{post.title[0]}</span>
        </div>
      )
    }
  </a>
  <div class="blog-card-body">
    {post.categories[0] && (
      <a
        href={`/blog/category/${slugify(post.categories[0])}/`}
        class="blog-card-category"
      >
        {post.categories[0]}
      </a>
    )}
    <a href={`/blog/${slug}/`} class="blog-card-link">
      <h2 class="blog-card-title">
        {post.title}
      </h2>
      <p class="blog-card-excerpt">{post.excerpt}</p>
    </a>
    <div class="blog-card-meta">
      <span>{post.author}</span>
      <span>·</span>
      <time datetime={post.date}>{formatDate(post.date)}</time>
    </div>
  </div>
</article>
