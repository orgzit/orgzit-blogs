---
interface Props {
  name:   string;
  slug:   string;
  bio:    string;
  avatar: string;
}

const { name, slug, bio, avatar } = Astro.props;
---
<div class="mt-12 pt-8 border-t border-slate-200 flex gap-4">
  {avatar
    ? <img src={avatar} alt={name} class="w-14 h-14 rounded-full flex-shrink-0" width="56" height="56" />
    : <div class="w-14 h-14 rounded-full bg-brand-100 flex items-center justify-center flex-shrink-0">
        <span class="text-brand-600 font-bold text-lg">{name[0]}</span>
      </div>
  }
  <div>
    <a href={`/blog/author/${slug}/`} class="font-semibold text-slate-900 hover:text-brand-600 transition-colors">
      {name}
    </a>
    {bio && <p class="text-slate-600 text-sm mt-1 leading-relaxed">{bio}</p>}
  </div>
</div>
