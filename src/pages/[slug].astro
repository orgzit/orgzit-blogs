---
import { getCollection } from 'astro:content';
import BlogPostLayout from '@layouts/BlogPostLayout.astro';
import TableOfContents from '@components/blog/TableOfContents.astro';
import AuthorCard from '@components/blog/AuthorCard.astro';
import ShareButtons from '@components/ui/ShareButtons.astro';
import { getReadingTime } from '@lib/readingTime';
import { getRelatedPosts } from '@lib/related';
import { formatDate, isoDate } from '@lib/dates';
import { withBase } from '@lib/paths';
import { slugify } from '@lib/slugify';
import type { Post } from '@app-types/blog';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map(post => ({
    params: { slug: post.slug },
    props:  { post },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await post.render();

const readingTime = getReadingTime(post.body ?? '');

// Build TOC from Astro's headings (depth 2 and 3 only)
const toc = headings
  .filter(h => h.depth === 2 || h.depth === 3)
  .map(h => ({ level: h.depth as 2 | 3, id: h.slug, text: h.text }));

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const postData: Post = { ...post.data, slug: post.slug, readingTime };
const relatedPosts = getRelatedPosts(
  postData,
  allPosts.map(p => ({ ...p.data, slug: p.slug, readingTime: 5 })),
  9,
);

const postUrl = `https://orgzit.com/blog/${post.slug}/`;
const catSlug = slugify;

const siteUrl = 'https://orgzit.com';
const rawImage = post.data.ogImage || post.data.featuredImage || '/blog-images/default-og.png';
const ogImageFull = rawImage.startsWith('http') ? rawImage : `${siteUrl}${withBase(rawImage)}`;
---
<BlogPostLayout
  title={post.data.seoTitle}
  description={post.data.seoDescription}
  canonical={post.data.canonicalUrl}
  ogImage={ogImageFull}
  noIndex={post.data.noIndex}
  publishedAt={isoDate(post.data.date)}
  updatedAt={post.data.updatedDate ? isoDate(post.data.updatedDate) : undefined}
  author={post.data.author}
  pagefindCategory={post.data.categories[0] ?? ''}
  toc={toc}
  relatedPosts={relatedPosts}
  breadcrumbItems={[
    { label: 'Blog', href: '/blog/' },
    ...(post.data.categories[0]
      ? [{ label: post.data.categories[0], href: `/blog/category/${catSlug(post.data.categories[0])}/` }]
      : []),
    { label: post.data.title },
  ]}
  jsonLdArticle={{
    "@context": "https://schema.org",
    "@type": "Article",
    "headline":     post.data.title,
    "description":  post.data.seoDescription,
    "image":        ogImageFull,
    "datePublished": isoDate(post.data.date),
    "dateModified":  post.data.updatedDate ? isoDate(post.data.updatedDate) : isoDate(post.data.date),
    "author": {
      "@type": "Person",
      "name":  post.data.author,
      "url":   `https://orgzit.com/blog/author/${post.data.authorSlug}/`,
    },
    "publisher": {
      "@type": "Organization",
      "name":  "Orgzit",
      "logo":  { "@type": "ImageObject", "url": "https://orgzit.com/logo.png" },
    },
    "mainEntityOfPage": { "@type": "WebPage", "@id": postUrl },
  }}
  jsonLdBreadcrumb={{
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://orgzit.com/" },
      { "@type": "ListItem", "position": 2, "name": "Blog", "item": "https://orgzit.com/blog/" },
      ...(post.data.categories[0]
        ? [{ "@type": "ListItem", "position": 3, "name": post.data.categories[0],
             "item": `https://orgzit.com/blog/category/${catSlug(post.data.categories[0])}/` }]
        : []),
      { "@type": "ListItem", "position": post.data.categories[0] ? 4 : 3, "name": post.data.title },
    ],
  }}
>
  <header class="post-header">
    {post.data.categories[0] && (
      <a
        href={`/blog/category/${catSlug(post.data.categories[0])}/`}
        class="post-category-badge"
      >
        {post.data.categories[0]}
      </a>
    )}

    <h1 class="post-title">
      {post.data.title}
    </h1>

    <div class="post-meta">
      {post.data.authorAvatar && (
        <img
          src={post.data.authorAvatar}
          alt={post.data.author}
          class="post-meta-avatar"
          width="32" height="32"
        />
      )}
      <span class="post-meta-author">{post.data.author}</span>
      <span>·</span>
      <time datetime={isoDate(post.data.date)}>{formatDate(post.data.date)}</time>
      <span>·</span>
      <span>{readingTime} min read</span>
      {post.data.updatedDate && post.data.updatedDate !== post.data.date && (
        <>
          <span>·</span>
          <span>Updated {formatDate(post.data.updatedDate)}</span>
        </>
      )}
    </div>

    {post.data.featuredImage && (
      <div class="post-hero-image">
        <img
          src={withBase(post.data.featuredImage)}
          alt={post.data.featuredImageAlt}
          class="post-hero-img"
          loading="eager"
          width="1200" height="675"
        />
      </div>
    )}
  </header>

  {toc.length > 2 && (
    <div class="post-toc-mobile">
      <TableOfContents items={toc} />
    </div>
  )}

  <div class="post-content">
    <Content />
  </div>

  {post.data.tags.length > 0 && (
    <div class="post-tags">
      <div class="post-tags-list">
        {post.data.tags.map(tag => (
          <a
            href={`/blog/tag/${slugify(tag)}/`}
            class="post-tag"
          >
            #{tag}
          </a>
        ))}
      </div>
    </div>
  )}

  <ShareButtons url={postUrl} title={post.data.title} />

  <AuthorCard
    name={post.data.author}
    slug={post.data.authorSlug}
    bio={post.data.authorBio ?? ''}
    avatar={post.data.authorAvatar ?? ''}
  />
</BlogPostLayout>
