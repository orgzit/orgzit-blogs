---
import { getCollection } from 'astro:content';
import BlogListingLayout from '@layouts/BlogListingLayout.astro';
import BlogCard from '@components/blog/BlogCard.astro';
import authorsData from '@/content/data/authors.json';

export async function getStaticPaths() {
  const authors = authorsData as any[];
  return authors.map(author => ({
    params: { author: author.slug },
    props:  { author },
  }));
}

const { author } = Astro.props;
const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const posts = allPosts
  .filter(p => p.data.authorSlug === author.slug)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---
<BlogListingLayout
  title={`${author.name} — Orgzit Blog`}
  description={author.description || `Articles by ${author.name} on the Orgzit Blog.`}
  canonical={`https://orgzit.com/blog/author/${author.slug}/`}
>
  <div class="archive-author-header">
    {author.avatar_urls?.['96'] && (
      <img
        src={author.avatar_urls['96']}
        alt={author.name}
        class="archive-author-avatar"
        width="80" height="80"
      />
    )}
    <div class="archive-author-info">
      <h1 class="archive-title">{author.name}</h1>
      {author.description && (
        <p class="archive-author-bio" set:html={author.description} />
      )}
      <p class="archive-count">{posts.length} articles</p>
    </div>
  </div>
  <div class="blog-grid">
    {posts.map(post => <BlogCard post={post.data} slug={post.slug} />)}
  </div>
</BlogListingLayout>
