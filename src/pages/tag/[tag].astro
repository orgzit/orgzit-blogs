---
import { getCollection } from 'astro:content';
import BlogListingLayout from '@layouts/BlogListingLayout.astro';
import BlogCard from '@components/blog/BlogCard.astro';
import tagsData from '@/content/data/tags.json';
import { slugify } from '@lib/slugify';

export async function getStaticPaths() {
  const tags = tagsData as any[];
  return tags.map(tag => ({
    params: { tag: tag.slug },
    props:  { tag },
  }));
}

const { tag } = Astro.props;
const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const posts = allPosts
  .filter(p =>
    p.data.tags
      .map(t => slugify(t))
      .includes(tag.slug)
  )
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---
<BlogListingLayout
  title={`#${tag.name} — Orgzit Blog`}
  description={`All posts tagged ${tag.name} on the Orgzit Blog.`}
  canonical={`https://orgzit.com/blog/tag/${tag.slug}/`}
>
  <div class="archive-header">
    <h1 class="archive-title">#{tag.name}</h1>
    <p class="archive-count">{posts.length} articles</p>
  </div>
  <div class="blog-grid">
    {posts.map(post => <BlogCard post={post.data} slug={post.slug} />)}
  </div>
</BlogListingLayout>
