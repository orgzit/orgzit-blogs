---
import type { GetStaticPaths } from 'astro';
import { getCollection } from 'astro:content';
import BlogListingLayout from '@layouts/BlogListingLayout.astro';
import BlogCard from '@components/blog/BlogCard.astro';
import Pagination from '@components/ui/Pagination.astro';

export const getStaticPaths: GetStaticPaths = async ({ paginate }) => {
  const POSTS_PER_PAGE = 12;
  const allPosts = await getCollection('blog', ({ data }) => !data.draft);
  const sorted = allPosts.sort((a, b) =>
    new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
  );
  return paginate(sorted, { pageSize: POSTS_PER_PAGE });
};

const { page } = Astro.props as any;
---
<BlogListingLayout
  title={`Orgzit Blog — Page ${page.currentPage}`}
  description="Practical guides on CRM, productivity, no-code tools, and business automation."
  canonical={`https://orgzit.com/blog/page/${page.currentPage}/`}
>
  <h1 class="section-heading">
    All Articles — Page {page.currentPage}
  </h1>
  <div class="blog-grid">
    {page.data.map((post: any) => <BlogCard post={post.data} slug={post.slug} />)}
  </div>
  <Pagination currentPage={page.currentPage} totalPages={page.lastPage} baseUrl="/blog" />
</BlogListingLayout>
